  "description": "Import from OAM based on ROR ID",
  "strategy_type": 2,
  "strategy": {
    "format": "json",
    "max_res": 100,
    "delayInMs": 0,
    "get_count": "$.n",
    "get_items": "$.cursor.batch",
    "url_count": "https://open-access-monitor.de/api/Data/public?token=[SECRET_OAM]&query={count:\"Publications\", query:{year:[year], \"source_data.organisations._id\": { $in:%5B\"[ror_id|join:\",\"]\"%5D}}}",
    "url_items": "https://open-access-monitor.de/api/Data/public?token=[SECRET_OAM]&query={find:\"Publications\", filter:{year:[year], \"source_data.organisations._id\": { $in:%5B\"[ror_id|join:\",\"]\"%5D}}, limit:100, skip:[offset]}",
    "offset_name": "skip",
    "max_res_name": "limit",
    "offset_count": 0,
    "offset_start": 0,
    "request_mode": "offset",
    "parallelCalls": 1,
    "exclusion_criteria": "false",
    "search_text_combiner": ",",
    "only_import_if_authors_inst": true
  },
  "mapping": "{\n  \"doi\": $.doi,\n  \"pub_type\": $.\"publication_type\",\n  \"oa_category\": (\n   $oa_mapping := {\n    \"0\": \"Closed\",\n    \"1\": \"Bronze\",\n    \"3\": \"Green\",\n    \"4\": \"Green\",\n    \"5\": \"Green\",\n    \"6\": \"Hybrid\",\n    \"7\": \"Gold\",\n    \"8\": \"Diamond\"\n  };\n   $mapped_value := $lookup($oa_mapping, $string($.oa_color));\n   $mapped_value ? $mapped_value : null\n),\n  \"greater_entity\": {\n  \"label\": $.journal.title,\n  \"identifiers\": $.journal.issns ? $.journal.issns[].{\n          \"type\" : \"issn\",\n          \"value\" : $\n        } : undefined\n},\n  \"publisher\": {\n   \"label\": $.publisher.name\n},\n  \"pub_date\": (\n   $parts := $.published_date ? $split($.published_date, \"-\") : [];\n   $count($parts) = 3 ? \n    (\n      $y := $parts[0];\n      $m := $length($parts[1]) = 1 ? \"0\" & $parts[1] : $parts[1];\n      $d := $length($parts[2]) = 1 ? \"0\" & $parts[2] : $parts[2];\n      \n      $y & \"-\" & $m & \"-\" & $d & \"T00:00:00.000Z\"\n    ) \n  : \n    ( \n      $.published_date \n    )\n),\n  \"license\": $.license,\n  \"status\": 0\n}",
  "update_config": {
    "doi": 2,
    "link": 2,
    "title": 2,
    "funder": 3,
    "status": 2,
    "authors": 2,
    "invoice": 2,
    "license": 2,
    "abstract": 2,
    "citation": 2,
    "contract": 2,
    "language": 2,
    "pub_date": 2,
    "pub_type": 2,
    "publisher": 2,
    "page_count": 2,
    "author_inst": 3,
    "oa_category": 2,
    "cost_approach": 2,
    "peer_reviewed": 2,
    "greater_entity": 2
  },
  "locked_at": null
}