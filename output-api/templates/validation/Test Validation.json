{
  "id": 1,
  "workflow_id": "df5c36a8-29de-4a6d-a55d-6a4930442704",
  "label": "Test-Validation",
  "version": 1,
  "created_at": "2026-04-24T11:12:25.991Z",
  "modified_at": "2026-04-24T12:04:00.058Z",
  "published_at": null,
  "deleted_at": null,
  "description": "Demonstriert die Fähigkeiten eines Validierungs-Workflows",
  "mapping": null,
  "locked_at": "2026-04-24T12:04:00.055Z",
  "target": "publication",
  "target_filter": {
    "expressions": []
  },
  "rules": [
    {
      "path": "authors",
      "type": "required",
      "result": "warning"
    },
    {
      "comp": 2,
      "path": "doi",
      "type": "compare",
      "value": "10.",
      "negate": false,
      "result": "error"
    },
    {
      "if": [
        {
          "comp": 0,
          "path": "publisher.label",
          "type": "compare",
          "value": "MDPI",
          "negate": false
        }
      ],
      "then": [
        {
          "comp": 5,
          "path": "oa_category.label",
          "type": "compare",
          "value": [
            "Gold",
            "Diamond"
          ],
          "negate": false
        }
      ],
      "type": "conditional",
      "result": "info"
    }
  ]
}