{
   "name": "output",
   "version": "2.0.0-dev",
   "description": "Publication management for universities.",
   "overrides": {
      "picomatch": "4.0.4",
      "path-to-regexp": "8.4.1"
   },
   "devDependencies": {
      "@eslint/js": "^10.0.1",
      "@nestjs/testing": "^11.1.17",
      "@types/cookie-parser": "^1.4.10",
      "@types/jest": "^30.0.0",
      "@types/multer": "^2.1.0",
      "@types/node": "^25.5.0",
      "eslint": "^10.1.0",
      "globals": "^17.4.0",
      "jest": "^30.3.0",
      "rimraf": "^6.1.3",
      "ts-jest": "^29.4.6",
      "ts-node": "^10.9.2",
      "typescript": "^5.9.3",
      "typescript-eslint": "^8.58.0"
   },
   "dependencies": {
      "@nestjs/axios": "4.0.1",
      "@nestjs/cli": "^11.0.17",
      "@nestjs/common": "^11.1.17",
      "@nestjs/config": "^4.0.3",
      "@nestjs/core": "^11.1.17",
      "@nestjs/jwt": "^11.0.2",
      "@nestjs/passport": "^11.0.5",
      "@nestjs/platform-express": "^11.1.17",
      "@nestjs/schedule": "^6.1.1",
      "@nestjs/serve-static": "^5.0.4",
      "@nestjs/swagger": "^11.2.6",
      "@nestjs/typeorm": "^11.0.0",
      "axios": "^1.14.0",
      "body-parser": "^2.2.2",
      "class-transformer": "^0.5.1",
      "class-validator": "^0.15.1",
      "cookie-parser": "^1.4.7",
      "cross-env": "^10.1.0",
      "express": "^5.2.1",
      "https": "^1.0.0",
      "jiti": "^2.6.1",
      "jsonata": "^2.1.0",
      "moment": "^2.30.1",
      "mysql": "^2.18.1",
      "node": "^25.8.2",
      "papaparse": "^5.5.3",
      "passport": "^0.7.0",
      "passport-local": "^1.0.0",
      "pg": "^8.20.0",
      "reflect-metadata": "^0.2.2",
      "rxjs": "^7.8.2",
      "swagger-ui-express": "^5.0.1",
      "typeorm": "^0.3.28",
      "uuid": "^13.0.0",
      "xlsx": "npm:@e965/xlsx@0.20.3",
      "xml-js": "^1.6.11",
      "zod": "^4.3.6"
   },
   "scripts": {
      "prebuild": "rimraf dist",
      "i": "npm i",
      "audit": "npm audit",
      "build": "nest build",
      "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
      "start": "node -v && cross-env NODE_ENV=dev nest start -c nest-cli.dev.json -p tsconfig.json",
      "start:dev": "node -v && cross-env NODE_ENV=dev nest start -c nest-cli.dev.json -p tsconfig.json --watch",
      "start:debug": "nest start -c nest-cli.dev.json -p tsconfig.json --debug --watch",
      "start:test": "node -v && cross-env NODE_ENV=test node dist/output-api/src/main --watch",
      "start:prod": "node -v && cross-env NODE_ENV=prod node dist/output-api/src/main --watch",
      "start:init": "node -v && cross-env NODE_ENV=dev nest start -c nest-cli.init.json -p tsconfig.json",
      "start:init_test": "node -v && cross-env NODE_ENV=test nest start -c nest-cli.init.json -p tsconfig.json",
      "start:init_prod": "node -v && cross-env NODE_ENV=prod nest start -c nest-cli.init.json -p tsconfig.json",
      "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
      "test": "jest",
      "test:watch": "jest --watch",
      "test:cov": "jest --coverage",
      "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
      "test:e2e": "jest --config ./test/jest-e2e.json",
      "typeorm:dev": "cross-env NODE_ENV=dev typeorm-ts-node-commonjs",
      "typeorm:test": "cross-env NODE_ENV=test typeorm-ts-node-commonjs",
      "typeorm:prod": "cross-env NODE_ENV=prod typeorm-ts-node-commonjs",
      "typeorm-js": "typeorm"
   }
}
