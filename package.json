{
  "name": "output-workspace",
  "private": true,
  "scripts": {
    "build:interfaces": "npm --workspace @output/interfaces run build",
    "watch:interfaces": "npm --workspace @output/interfaces run watch",
    "build:api": "npm run build:interfaces && npm --workspace output run build",
    "build:ui": "npm run build:interfaces && npm --workspace output-ui run build",
    "build:ui:prod": "npm run build:interfaces && npm --workspace output-ui run build:prod",
    "start:api": "npm run build:interfaces && npm --workspace output run start",
    "start:ui": "npm run build:interfaces && npm --workspace output-ui run start",
    "dev:api": "npm run build:interfaces && concurrently -k -n interfaces,api \"npm run watch:interfaces\" \"npm --workspace output run start:dev\"",
    "dev:ui": "npm run build:interfaces && concurrently -k -n interfaces,ui \"npm run watch:interfaces\" \"npm --workspace output-ui run start\"",
    "dev": "npm run build:interfaces && concurrently -k -n interfaces,api,ui \"npm run watch:interfaces\" \"npm --workspace output run start:dev\" \"npm --workspace output-ui run start\"",
    "licenses:generate": "node scripts/generate-third-party-notices.mjs",
    "licenses:check": "npm run licenses:generate"
  },
  "workspaces": [
    "output-api",
    "output-ui",
    "output-interfaces"
  ],
  "devDependencies": {
    "@angular/build": "20.3.31",
    "@angular/cli": "20.3.25",
    "@angular/compiler-cli": "20.3.25",
    "@angular/localize": "20.3.25",
    "@eslint/js": "^10.0.1",
    "@nestjs/testing": "^11.1.27",
    "@types/cookie-parser": "^1.4.10",
    "@types/jasmine": "~5.1.12",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.2",
    "concurrently": "^10.0.3",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "jasmine-core": "~5.12.1",
    "jest": "^30.3.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~1.7.0",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1"
  },
  "dependencies": {
    "@angular/animations": "20.3.25",
    "@angular/cdk": "20.2.14",
    "@angular/common": "20.3.25",
    "@angular/compiler": "20.3.25",
    "@angular/core": "20.3.25",
    "@angular/forms": "20.3.25",
    "@angular/material": "20.2.14",
    "@angular/material-moment-adapter": "20.2.14",
    "@angular/platform-browser": "20.3.25",
    "@angular/platform-browser-dynamic": "20.3.25",
    "@angular/router": "20.3.25",
    "@nestjs/axios": "4.0.1",
    "@nestjs/cli": "^11.0.18",
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.18",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/typeorm": "^11.0.1",
    "@ng-bootstrap/ng-bootstrap": "19.0.1",
    "@ngrx/store": "20.1.0",
