{
  "name": "output-ui",
  "version": "0.0.0",
  "scripts": {
    "ensure:interfaces": "npm --workspace @output/interfaces run build",
    "ng": "ng",
    "start": "npm run ensure:interfaces && ng serve --host=127.0.0.1 --proxy-config proxy.conf.json",
    "build": "npm run ensure:interfaces && ng build",
    "build:prod": "npm run ensure:interfaces && ng build --configuration production",
    "watch": "npm run ensure:interfaces && ng build --watch --configuration development",
    "test": "npm run ensure:interfaces && ng test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "20.3.25",
    "@angular/cdk": "20.2.14",
    "@angular/common": "20.3.25",
    "@angular/compiler": "20.3.25",
    "@angular/core": "20.3.25",
    "@angular/forms": "20.3.25",
    "@angular/material": "20.2.14",
    "@angular/material-moment-adapter": "20.2.14",
    "@angular/platform-browser": "20.3.25",
    "@angular/platform-browser-dynamic": "20.3.25",
    "@angular/router": "20.3.25",
    "@ng-bootstrap/ng-bootstrap": "19.0.1",
    "@ngrx/store": "20.1.0",
    "@ngrx/store-devtools": "20.1.0",
    "@output/interfaces": "*",
    "@popperjs/core": "^2.10.2",
    "bootstrap": "^5.2.3",
    "echarts": "^6.0.0",
    "moment": "^2.29.4",
    "ngx-cookie-service": "^20.1.0",
    "ngx-echarts": "^20.0.2",
    "rxjs": "~7.5.0",
    "service": "^0.1.4",
    "tslib": "^2.3.0",
    "xlsx": "npm:@e965/xlsx@0.20.3",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular/build": "20.3.31",
    "@angular/cli": "20.3.25",
    "@angular/compiler-cli": "20.3.25",
    "@angular/localize": "20.3.25",
    "@types/jasmine": "~5.1.12",
    "@types/node": "^12.11.1",
    "jasmine-core": "~5.12.1",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~1.7.0",
    "typescript": "^5.9.3"
  }
}
