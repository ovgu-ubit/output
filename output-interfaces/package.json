{
  "name": "@output/interfaces",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "require": "./dist/*.js",
      "default": "./dist/*.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "node -e \"const cp=require('child_process'); const tsc=require.resolve('typescript/bin/tsc'); cp.execFileSync(process.execPath,[tsc,'-p','tsconfig.json'],{stdio:'inherit'});\"",
    "watch": "node -e \"const cp=require('child_process'); const tsc=require.resolve('typescript/bin/tsc'); cp.execFileSync(process.execPath,[tsc,'-p','tsconfig.json','--watch','--preserveWatchOutput'],{stdio:'inherit'});\""
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3"
  }
}
